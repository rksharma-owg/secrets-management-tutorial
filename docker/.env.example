# Secret Provider Configuration
SECRET_PROVIDER=aws  # Options: aws, vault, azure

# AWS Configuration (use IAM roles in production, not keys)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key  # Prefer IAM roles over static keys
# AWS_SECRET_ACCESS_KEY=your-secret-key  # NEVER commit this file

# Vault Configuration
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-only-token  # Change in production!

# Azure Configuration
AZURE_VAULT_URL=https://your-vault-name.vault.azure.net/
AZURE_TENANT_ID=your-tenant-id

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=myapp