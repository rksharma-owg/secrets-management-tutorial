{
  // =============================================================================
  // appsettings.json
  //
  // SECURITY WARNING: This file should NEVER contain secrets.
  // All sensitive values (passwords, API keys, tokens) are retrieved from
  // the configured secret manager (AWS Secrets Manager, HashiCorp Vault,
  // or Azure Key Vault) at application startup.
  //
  // This file contains ONLY non-sensitive defaults and operational settings.
  // Secrets loaded from the secret manager OVERRIDE these values because
  // the secret manager configuration provider is registered AFTER the
  // default JSON providers (last provider wins in ASP.NET Core).
  // =============================================================================

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      // Reduce noise from AWS/Azure SDKs. Set to Debug for troubleshooting.
      "Microsoft.AspNetCore": "Warning",
      "Amazon.Runtime": "Warning",
      "Azure.Identity": "Information",
      "Azure.Security.KeyVault.Secrets": "Warning",
      "VaultSharp": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    },
    // SECURITY: The console logger must NEVER output secret values.
    // ASP.NET Core's structured logging passes values as parameters
    // (not string interpolation), so they can be filtered by log sinks.
    "Console": {
      "FormatterName": "systemd",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss"
      }
    }
  },

  "AllowedHosts": "*",

  // These values are safe defaults. In production, the secret manager
  // overrides the connection-related settings. These placeholders exist
  // so that the configuration structure is clear and local development
  // can work without a secret manager (using non-production values).
  "Database": {
    // These are overridden at runtime by the secret manager.
    // DO NOT put real values here.
    "Host": "localhost",
    "Port": 1433,
    "DatabaseName": "tutorial-db"
  },

  "Jwt": {
    // These are overridden at runtime by the secret manager.
    "Issuer": "https://localhost:5001",
    "Audience": "secrets-tutorial-api",
    "ExpiryMinutes": 15
  },

  "OpenAI": {
    // These are overridden at runtime by the secret manager.
    "Model": "gpt-4",
    "MaxTokens": 2048
  }
}